{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Swarm Training Pair",
  "description": "Schema for a single training pair used across all Swarm verticals.",
  "type": "object",
  "required": ["instruction", "response", "score", "domain"],
  "properties": {
    "instruction": {
      "type": "string",
      "minLength": 10,
      "description": "The input prompt or instruction."
    },
    "response": {
      "type": "string",
      "minLength": 50,
      "description": "The model response."
    },
    "score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Quality score from eval or CoVe pipeline."
    },
    "domain": {
      "type": "string",
      "minLength": 1,
      "description": "Domain tag (e.g. signal, aviation)."
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata (verdict, trajectory step, specialty, format, source, etc.)."
    }
  },
  "additionalProperties": false
}
